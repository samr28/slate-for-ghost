<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    {{! Page Meta }}
    <title>{{meta_title}}</title>

    {{> head}}

    {{ghost_head}}

    {{!-- Dark mode — loads last to override Ghost's inline :root styles --}}
    <link href="{{asset 'css/dark-mode.css' }}" type="text/css" rel="stylesheet">

</head>
<body class="{{#if @site.cover_image}}cover{{/if}} {{body_class}}" {{#if @site.cover_image}}style="background: url({{@site.cover_image}}) no-repeat center center fixed;"{{/if}}>
    
    <img loading="eager" fetchpriority="high" src="{{asset 'images/svg-icons.svg'}}" alt="Social Icons" style="display:none;">

    <!-- start: .mobile.main-nav -->
    <nav class="mobile main-nav">
        {{>site-logo}}
        {{navigation}}
        {{#if @site.members_enabled}}
            <div class="nav-login">          
                {{#if @member}}
                    <a data-members-signout class="link-button">{{t "Sign Out"}}</a>
                    <a href="javascript:void(0)" data-portal="account" class="epcl-button">{{t "My Account"}}</a>                
                {{else}}
                    <a data-portal="signin" class="link-button">
                        {{t "Login"}}
                    </a>
                    <a data-portal="subscribe" class="epcl-button">
                        <svg width="16" height="15" viewBox="0 0 16 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M11.6 0C14.0301 0 16 1.97368 16 4.73684C16 5.86192 15.7513 6.88887 15.3383 7.821C14.6019 7.36737 13.732 7.10526 12.8 7.10526C10.149 7.10526 8 9.22603 8 11.8421C8 12.7109 8.23704 13.5251 8.65072 14.2251C8.4048 14.369 8.18528 14.4956 8 14.6053C6.00001 13.4211 0 10.2632 0 4.73684C0 1.97368 2 0 4.4 0C5.88798 0 7.2 0.789474 8 1.57895C8.8 0.789474 10.112 0 11.6 0ZM13.6 11.0526V8.68421H12V11.0526H9.6V12.6316H11.9992L12 15H13.6L13.5992 12.6316H16V11.0526H13.6Z" fill="white"/>
                        </svg>
                        {{t "Join"}}
                    </a>                                                            
                {{/if}}
            </div>
        {{/if}}
    </nav>
    <!-- end: .mobile.main-nav -->
    
    <div class="menu-overlay"></div>

	<!-- start: #wrapper -->
	<div id="wrapper">

		{{> header}}

        {{{body}}}

		{{> footer}}        

    </div>
    <!-- end: #wrapper -->

    {{ghost_foot}}

    {{!-- Theme Scripts --}}
    <script defer src="{{asset 'dist/scripts.min.js' }}"></script>
    <script defer src="{{asset 'js/dark-mode.js' }}"></script>


</body>
</html>
