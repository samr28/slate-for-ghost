{{! Custom Fonts }}

<style>
/* open-sans - latin (variable font, normal, weights 300-700) */
@font-face {
  font-display: swap;
  font-family: 'Open Sans';
  font-style: normal;
  font-weight: 300 700;
  src: url({{asset "fonts/open-sans-v44-latin-normal.woff2"}}) format('woff2');
}
/* open-sans - latin (variable font, italic, weights 400-700) */
@font-face {
  font-display: swap;
  font-family: 'Open Sans';
  font-style: italic;
  font-weight: 400 700;
  src: url({{asset "fonts/open-sans-v44-latin-italic.woff2"}}) format('woff2');
}

/* libre-baskerville-regular - latin */
@font-face {
  font-display: swap;
  font-family: 'Libre Baskerville';
  font-style: normal;
  font-weight: 400;
  src: url({{asset "fonts/libre-baskerville-v24-latin-regular.woff2"}}) format('woff2');
}
/* libre-baskerville-italic - latin */
@font-face {
  font-display: swap;
  font-family: 'Libre Baskerville';
  font-style: italic;
  font-weight: 400;
  src: url({{asset "fonts/libre-baskerville-v24-latin-italic.woff2"}}) format('woff2');
}
</style>

