<!-- start: #header -->
<header id="header" class="minimalist">

	<div class="menu-mobile">
        <svg class="icon ularge open"><use xlink:href="{{asset 'images/svg-icons.svg#menu-icon'}}"></use></svg>
        <svg class="icon ularge close"><use xlink:href="{{asset 'images/svg-icons.svg#close-icon'}}"></use></svg>
    </div>

    <span data-ghost-search class="epcl-search-button hide-on-desktop-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon ularge lucide lucide-search-icon lucide-search"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg></span>

	<!-- start: .menu-wrapper -->
	<div class="menu-wrapper">
	
		<div class="grid-container grid-large">  

            <div class="epcl-flex">
                {{> site-logo }}
                <!-- start: .main-nav -->
                <nav class="main-nav">      
                    {{navigation}}     
                    <div class="clear"></div>             
                </nav>
                <!-- end: .main-nav -->

                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
                    <!-- Sun (shown in light mode) -->
                    <svg class="icon-sun" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="4"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                    </svg>
                    <!-- Moon (shown in dark mode) -->
                    <svg class="icon-moon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                </button>

                <div class="clear"></div>
            </div>		
            
            <div class="clear"></div>
        </div>
		
	</div>
	<!-- end: .menu-wrapper -->
	
	<div class="clear"></div>

</header>
<!-- end: #header -->